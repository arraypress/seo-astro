{
  "name": "@arraypress/seo-astro",
  "version": "1.0.1",
  "description": "Idiomatic <SEO> component for Astro — title, canonical, Open Graph, Twitter, robots, hreflang, article meta + JSON-LD. A thin wrapper over @arraypress/seo.",
  "type": "module",
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./SEO.astro": "./src/SEO.astro",
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "astro",
    "astro-component",
    "seo",
    "open-graph",
    "twitter-cards",
    "json-ld",
    "meta-tags",
    "withastro"
  ],
  "author": "ArrayPress",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arraypress/seo-astro.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@arraypress/seo": "^1.0.0"
  },
  "peerDependencies": {
    "astro": "^6.0.0 || ^7.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "astro": "^6.3.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
