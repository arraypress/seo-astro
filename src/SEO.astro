---
/**
 * SEO.astro
 * ---------
 *
 * Idiomatic Astro wrapper over @arraypress/seo's `buildHead()`. Drop it in
 * your `<head>` with the same options `buildHead` accepts — title, description,
 * canonical url, image, Open Graph + Twitter, robots, hreflang, article meta,
 * verification, and JSON-LD — and it renders the full set of tags for you.
 *
 * @example
 *   ---
 *   import { SEO } from '@arraypress/seo-astro';
 *   ---
 *   <head>
 *     <meta charset="utf-8" />
 *     <SEO
 *       title="My Page"
 *       description="A great page"
 *       image="/og.png"
 *       siteName="Example"
 *     />
 *
 *   The canonical is derived from the current URL automatically (tracking
 *   params stripped); pass `url` only to override it.
 *   </head>
 */
import { buildHead, canonicalize } from '@arraypress/seo';
import type { SEOProps } from './types';

// Auto-derive the canonical (and og:url) from the current request URL —
// tracking params stripped — unless an explicit `url` is passed.
const { url, ...rest } = Astro.props as SEOProps;
const head = buildHead({ url: url ?? canonicalize(Astro.url.href), ...rest });
---
<Fragment set:html={head} />
